import nltk, string
from nltk.corpus import stopwords
from nltk.stem import PorterStemmer
from sklearn.feature_extraction.text import CountVectorizer, TfidfVectorizer

nltk.download('stopwords')

text = "Natural Language Processing is very interesting and useful!".lower()
text = text.translate(str.maketrans('', '', string.punctuation))

words = [PorterStemmer().stem(w) for w in text.split() if w not in stopwords.words('english')]
print("Processed:", words)

text = " ".join(words)

bow = CountVectorizer().fit_transform([text])
print("\nBoW:", bow.toarray())

tfidf = TfidfVectorizer().fit_transform([text])
print("TF-IDF:", tfidf.toarray()) 

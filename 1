#11 Word embedding and tokenisation

from gensim.models import Word2Vec
#Sampledata
sentences = [
["I", "love", "NLP"],
["NLP", "is", "fun"],
["I", "enjoy", "learning"]
]

model = Word2Vec(sentences, vector_size=50, window=3, min_count=1)

sim1 =model.wv.similarity("NLP", "learning")
sim2 = model.wv.similarity("love", "enjoy")
print("Similarity (NLP, learning):", sim1)
print("Similarity (love, enjoy):", sim2)


